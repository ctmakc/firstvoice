# Database
DATABASE_URL=postgresql+asyncpg://fv:devpass@postgres:5432/firstvoice
SYNC_DATABASE_URL=postgresql://fv:devpass@postgres:5432/firstvoice

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=firstvoice
MINIO_SECRET_KEY=devpass123
MINIO_BUCKET=recordings
MINIO_SECURE=false

# NextAuth
NEXTAUTH_SECRET=change-me-in-production-32-char-secret
NEXTAUTH_URL=http://localhost:3050

# Google OAuth (for NextAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini AI
GEMINI_API_KEY=

# Web3 / Polygon Amoy Testnet
POLYGON_RPC=https://rpc-amoy.polygon.technology
PROVENANCE_CONTRACT_ADDRESS=
RELAYER_PRIVATE_KEY=

# Environment
APP_ENV=development
DEBUG=true

# Public site URL (canonical/OG/sitemap base for the web app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
